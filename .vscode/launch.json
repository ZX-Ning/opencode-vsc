{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run OpenCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "env": {
        "OPENCODE_WORKSPACE_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--folder-uri=file://${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build-extension"
    }
  ]
}
